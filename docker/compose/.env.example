# FamilyGram Web (telegram-tt container — must match credentials from my.telegram.org)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
WEB_DOMAIN=web.example.com
WEB_BASE_URL=https://web.example.com/
WEB_HOST_PORT=8082
WEB_CONTAINER_PORT=8082
WEB_APP_NAME=FamilyGram Web
WEB_APP_TITLE=FamilyGram
FamilygramWebImage=familygram/familygram-web:local

# FamilyGram Server (.NET MTProto backend) images — built and published by
# https://github.com/CyberoniOntoni/FamilyGram-Server CI to GHCR.
FamilyGramServerRegistry=ghcr.io/cyberoniontoni/familygram-server
FamilyGramServerVersion=latest
# Deprecated aliases (still honored by docker-compose.yml):
# TestgramRegistry=ghcr.io/cyberoniontoni/familygram-server
# TestgramVersion=latest

# session-server is still closed-source (Docker Hub only).
# file-server is built by FamilyGram-Server CI (GHCR). To force closed upstream:
# FileServerImage=mytelegram/mytelegram-file-server:latest
MyTelegramVersion=latest
MyTelegramRegistry=mytelegram
# RabbitMQ
RabbitMQ__Connections__Default__HostName=rabbitmq
RabbitMQ__Connections__Default__Port=5672
RabbitMQ__Connections__Default__UserName=test
RabbitMQ__Connections__Default__Password=CHANGE_ME
RabbitMQ__EventBus__ExchangeName=MyTelegramExchange

# Redis
Redis__Configuration=redis:6379

# MongoDB
ConnectionStrings__Default=mongodb://mongodb:27017

# Minio
Minio__Endpoint=minio:9000
Minio__AccessKey=test
Minio__SecretKey=CHANGE_ME
# IMPORTANT: Minio__BucketName MUST be set. docker-compose always passes this
# variable to file-server, so leaving it unset/commented becomes an EMPTY value.
# An empty bucket name makes the MinIO client throw "Bucket name cannot be empty" on
# every file request, which spams the console and breaks all media (avatars, stickers,
# verification icons, etc) from loading.
Minio__BucketName=tg-files
Minio__CreateBucketIfNotExists=True
# file-server talks to MinIO through the minio-proxy service by default, which works
# around a NullReferenceException in the file-server's bundled MinIO SDK on 416
# (range-past-EOF) responses. Only override this if you know what you are doing:
# Minio__FileServerEndpoint=minio-proxy:9000

# TwilioSms (disabled — login codes use @BotFather bot or App__FixedVerifyCode)
TwilioSms__Enabled=False
TwilioSms__AccountSId=
TwilioSms__AuthToken=
TwilioSms__FromNumber=
TwilioSms__MessagingServiceSId=

# VonageSms
# VonageSms__Enabled=False
# VonageSms__BrandName=
# VonageSms__ApiKey=
# VonageSms__ApiSecret=

# Email sender / 2FA recovery email
EmailSenderOptions__Enabled=False
EmailSenderOptions__FromAddress=no-reply@example.com
EmailSenderOptions__FromDisplayName=FamilyGram
EmailSenderOptions__SmtpEmailOptions__Host=smtp.example.com
EmailSenderOptions__SmtpEmailOptions__Port=587
EmailSenderOptions__SmtpEmailOptions__UserName=no-reply@example.com
EmailSenderOptions__SmtpEmailOptions__Password=CHANGE_ME
EmailSenderOptions__SmtpEmailOptions__EnableSsl=True

# Branding (white-label)
App__Brand=FamilyGram
App__WelcomeMsg=Welcome to FamilyGram! Your account has been created.
App__SendWelcomeMessageAfterUserSignIn=False
App__ProtectedUsernames__0=admin
App__ProtectedUsernames__1=botfather
App__ProtectedUsernames__2=support
App__ProtectedUsernames__3=telegram

# App
# App__PrivateKeyFilePath=private.pkcs8.key
# App__IdGeneratorGrpcServiceUrl=http://localhost:10002
App__DatabaseName=tg
App__ReadModelDatabaseName=tg
App__CreateTestUsers=False
App__AccessHashSecretKey=CHANGE_ME
App__EncryptionConfig__Enabled=True
App__EncryptionConfig__MessageKeys__0__Id=1
App__EncryptionConfig__MessageKeys__0__Key=CHANGE_ME
# App__EncryptionConfig__PhoneKey=
App__EncryptionConfig__IndexKeys__0__Id=1
App__EncryptionConfig__IndexKeys__0__Key=CHANGE_ME

# App__MyTelegramBotOptions__BotApiBaseUrl=http://bot-server:8080
# App__MyTelegramBotOptions__Token=
# App__MyTelegramBotOptions__WebHookUrl=http://localhost:10004/bot/ProcessBotCommand
# App__SubscribeLocalRequest=True
# App__SubscribeRemoteRequest=True
# App__UseExternalWebHookSender=False
# App__WebHookSenderUrl=
# App__ThisDcId=1
# App__MediaDcId=2
# App__UploadRootPath=uploads
# App__MediaOnly=False
# IMPORTANT: App__Servers__0__Enabled MUST be set to True.
# Port 20443 (server 0) is the main DC1 gateway that clients connect to first
# (see App__DcOptions__0__Port). docker-compose always passes this variable to the
# gateway container, so if it is left unset/commented it becomes an EMPTY value.
# An empty value makes .NET drop server 0 entirely, so the gateway never listens on
# 20443 and every client gets "ConnectionRefusedError". Keep the line below active.
App__Servers__0__Enabled=True
# App__Servers__0__ServerType=0
# App__Servers__0__Ip=
# App__Servers__0__Ipv6=True
App__Servers__0__Port=20443
App__Servers__1__Enabled=True
App__Servers__1__Port=20543
App__Servers__2__Enabled=True
App__Servers__2__Port=20643
App__Servers__3__Enabled=True
App__Servers__3__Port=20644
App__Servers__4__Enabled=True
# App__Servers__4__ServerType=1
App__Servers__4__Port=30443
App__Servers__5__Enabled=True
App__Servers__5__Port=30444
App__QueryServerEventStoreDatabaseName=tg
App__QueryServerReadModelDatabaseName=tg
App__BotDatabaseName=tg
App__FileServerGrpcServiceUrl=http://file-server:8080
# Login verification — choose ONE:
#   • @BotFather bot (default): set BOT_TOKEN, leave App__FixedVerifyCode empty, TelegramBotSms__Enabled=true
#   • Fixed code (private/lab): set App__FixedVerifyCode, leave BOT_TOKEN empty, TelegramBotSms__Enabled=false
#     (installer skips the bot container when using a fixed code)
TelegramBotSms__Enabled=true
App__FixedVerifyCode=
App__VerificationCodeLength=5
App__VerificationCodeExpirationSeconds=300
# App__JoinChatDomain=https://t.me
App__EnableEmailLogin=False
App__CheckPhoneNumberFormat=True
App__EnableSearchNonContacts=True
# WebRTC Configuration (REQUIRED for voice/video calls)
# You MUST configure at least one STUN/TURN server for calls to work
# Example with your own server:
App__WebRtcConnections__0__Ip=YOUR_SERVER_IP
App__WebRtcConnections__0__Ipv6=
App__WebRtcConnections__0__Port=5348
App__WebRtcConnections__0__Turn=True
App__WebRtcConnections__0__Stun=True
App__WebRtcConnections__0__UserName=testgram
App__WebRtcConnections__0__Password=testgram2024
# You can add more servers for redundancy:
# App__WebRtcConnections__1__Ip=BACKUP_SERVER_IP
# App__WebRtcConnections__1__Ipv6=
# App__WebRtcConnections__1__Port=5348
# App__WebRtcConnections__1__Turn=True
# App__WebRtcConnections__1__Stun=True
# App__WebRtcConnections__1__UserName=testgram
# App__WebRtcConnections__1__Password=testgram2024
App__DcOptions__0__Enabled=True
App__PasskeyRpId=your.domain.com
App__PasskeyRpName=FamilyGram

# Stripe (optional, for star gift purchases)
App__Stripe__PublishableKey=
App__Stripe__SecretKey=

App__DcOptions__0__IpAddress=YOUR_SERVER_IP
App__DcOptions__0__Port=20443
App__DcOptions__1__Enabled=True
App__DcOptions__1__IpAddress=YOUR_SERVER_IP
App__DcOptions__1__Port=20543
App__DcOptions__2__Enabled=True
App__DcOptions__2__IpAddress=YOUR_SERVER_IP
App__DcOptions__2__Port=20643
App__DcOptions__3__Enabled=True
App__DcOptions__3__Id=2
App__DcOptions__3__IpAddress=YOUR_SERVER_IP
App__DcOptions__3__Port=20644

# RTMP (optional — installer sets URLs when RTMP is enabled)
App__RtmpStreamUrl=
App__RtmpHlsUrl=

# Coturn host ports (installer sets from wizard; compose substitutes these)
PORT_STUN=5348
PORT_RELAY_MIN=49152
PORT_RELAY_MAX=49172
COTURN_EXTERNAL_IP=YOUR_SERVER_IP

# Serilog
Serilog__MinimumLevel__Default=Information
Serilog__MinimumLevel__Override__Microsoft=Warning

# Verification bot (delivers login codes to the Telegram account that linked a
# phone number - see the "bot" service). Built by this repo's CI as
# FamilyGramServerRegistry/familygram-server-bot.
BOT_TOKEN=your_bot_token_here
# Additional bots (optional): BOT_TOKEN1=..., BOT_TOKEN2=...
# PROXY_URL=socks5://user:pass@host:port
# Enable the RabbitMQ consumer in addition to the HTTP /send endpoint that
# sms-sender already calls by default.
# ENABLE_RABBITMQ_CONSUMER=true
