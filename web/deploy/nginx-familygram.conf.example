# FamilyGram Web — nginx on the Testgram LXC host (same machine as Docker Compose)
#
# Legacy manual nginx deploy. Prefer the unified stack: familygram-web container
# proxies /apiws to gateway-server:30444 on the Docker network (30444 is NOT on the host).
#
# If you still use host nginx, bind gateway 30444 to localhost only in an override, e.g.:
#   gateway-server ports: "127.0.0.1:30444:30444"
#
# Traffic chain (unified stack — recommended):
#   Browser wss://web.example.com/apiws
#     → NPM :443 → familygram-web :8082 → gateway-server:30444 (Docker internal)

map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

server {
    listen 8082;
    listen [::]:8082;
    server_name _;

    root /opt/familygram-web/dist;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    # Force fresh shell after deploy (fixes stale chunk references)
    location = /index.html {
        add_header Cache-Control "no-cache, no-store, must-revalidate";
    }

    location = /version.txt {
        add_header Cache-Control "no-cache";
    }

    location ~ ^/apiws(_premium|_test)?$ {
        proxy_pass http://127.0.0.1:30444;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_buffering off;
        proxy_read_timeout 86400;
        proxy_send_timeout 86400;
    }

    location ~ ^/apiw1(_premium|_test)?$ {
        proxy_pass http://127.0.0.1:30444;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_buffering off;
        proxy_read_timeout 86400;
        proxy_send_timeout 86400;
    }

    location /assets/ {
        expires 7d;
        add_header Cache-Control "public, immutable";
    }
}